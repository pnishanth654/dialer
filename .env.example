# --- Cloud database (free Postgres) ---
# Neon (https://neon.tech) or Supabase (https://supabase.com) — both have free tiers.
# Copy the connection string here. If left blank the server still boots (health only).
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# --- API auth / multi-account isolation ---
# Each person gets their OWN secret key, entered in the app + dashboard (sent as the
# `x-api-key` header). Each distinct key is a fully isolated account — accounts never
# see each other's call history. The key also IS the identity, so the same key on a new
# phone restores that person's history.
#
# REQUIRE_API_KEY=true  -> reject requests with no key (use this when sharing with people,
#                          so nobody's data merges into the shared default account).
# REQUIRE_API_KEY=false -> allow keyless requests (they hit a shared default account; fine
#                          for solo local testing).
REQUIRE_API_KEY=true
API_KEY=
DEFAULT_USER_EMAIL=owner@local

# --- Backup encryption (REQUIRED for Web3 backup) ---
# 64 hex chars = 32 bytes. Generate with:  npm run genkey
BACKUP_ENCRYPTION_KEY=

# --- Web3 storage provider ---
# WEB3_PROVIDER=pinata | local   (auto: pinata if PINATA_JWT is set, else local)
WEB3_PROVIDER=
# Pinata (https://pinata.cloud) free tier — create a JWT under API Keys.
PINATA_JWT=
PINATA_GATEWAY=https://gateway.pinata.cloud
# Where the `local` provider writes encrypted blobs (offline IPFS stand-in).
BACKUP_DIR=./backups

# --- Server ---
PORT=8080
# Nightly Web3 backup time (cron). Default 23:00 server time.
BACKUP_CRON=0 23 * * *
